<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- PATIENT FORM VIEW -->
  <record id="view_patient_form" model="ir.ui.view">
    <field name="name">health.patient.form</field>
    <field name="model">health.patient</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="risk_level" widget="statusbar" statusbar_visible="low,medium,high,critical"/>
        </header>
        <sheet>
          <!-- Smart Buttons -->
          <div class="oe_button_box" name="button_box">
            <button class="oe_stat_button" type="action" name="%(action_patient_vitals)d" icon="fa-heartbeat">
              <field string="Vitals" name="vitals_count" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" type="action" name="%(action_patient_alerts)d" icon="fa-bell">
              <field string="Total Alerts" name="alerts_count" widget="statinfo"/>
            </button>
            <button class="oe_stat_button" type="action" name="%(action_patient_critical_alerts)d" icon="fa-exclamation-triangle" context="{'search_default_critical': 1}">
              <div class="o_stat_info o_text_danger">
                <span class="o_stat_value"><field name="critical_alerts_count"/></span>
                <span class="o_stat_text">Critical</span>
              </div>
            </button>
          </div>

          <!-- Title Area -->
          <div class="oe_title mb-4">
            <h1 class="d-flex align-items-center">
              <field name="name" placeholder="Patient Name" class="me-3 sl-name-lead" style="font-size: 1.5em;"/>
              <span invisible="risk_level != 'critical'" class="badge rounded-pill text-bg-danger ms-2" style="font-size: 14px;">Critical Risk</span>
              <span invisible="risk_level != 'high'" class="badge rounded-pill text-bg-warning ms-2" style="font-size: 14px;">High Risk</span>
              <span invisible="risk_level != 'medium'" class="badge rounded-pill text-bg-info ms-2" style="font-size: 14px;">Medium Risk</span>
              <span invisible="risk_level != 'low'" class="badge rounded-pill text-bg-success ms-2" style="font-size: 14px;">Low Risk</span>
            </h1>
          </div>

          <!-- Structured Layout -->
          <div class="row sl-card-container">
            <div class="col-md-6 mb-3">
              <div class="sl-card shadow-sm p-4 bg-white rounded border-0">
                  <h3 class="o_horizontal_separator text-primary mb-3"><i class="fa fa-user-circle-o me-2"></i>Personal Profile</h3>
                  <group>
                    <field name="age"/>
                    <field name="gender" widget="radio" options="{'horizontal': true}"/>
                    <field name="category" widget="badge" 
                           decoration-info="category=='child'"
                           decoration-warning="category=='elderly'"
                           decoration-success="category=='adult'"
                           decoration-primary="category=='teen'"/>
                  </group>
              </div>
            </div>
            <div class="col-md-6 mb-3">
              <div class="sl-card shadow-sm p-4 bg-white rounded border-0">
                  <h3 class="o_horizontal_separator text-primary mb-3"><i class="fa fa-stethoscope me-2"></i>Medical Context</h3>
                  <group>
                    <field name="doctor_id" widget="many2one_avatar_user" options="{'no_create': True}"/>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                  </group>
              </div>
            </div>
          </div>
          <div class="row sl-card-container">
            <div class="col-md-12 mb-3">
              <div class="sl-card shadow-sm p-4 bg-white rounded border-0">
                  <h3 class="o_horizontal_separator text-primary mb-3"><i class="fa fa-brain me-2"></i>AI Risk Assessment</h3>
              <div class="sl-ai-alert-box" invisible="risk_level in ['low', 'medium']">
                <i class="fa fa-exclamation-triangle"></i>
                <div>
                  <strong>Attention Required</strong><br/>
                  <span style="font-size: 13px;">This patient has a high AI risk score. Please review latest vitals.</span>
                </div>
              </div>
              <div class="row">
                  <div class="col-md-6">
                      <group>
                        <field name="last_score" widget="progressbar" string="Latest AI Score" options="{'max_value': 1.0}"/>
                        <field name="last_alert_id" readonly="1" string="Latest Alert"/>
                      </group>
                  </div>
                  <div class="col-md-6">
                      <group>
                        <field name="risk_level" widget="badge" 
                               decoration-danger="risk_level=='critical'"
                               decoration-warning="risk_level=='high'"
                               decoration-info="risk_level=='medium'"
                               decoration-success="risk_level=='low'"/>
                      </group>
                  </div>
              </div>
              </div>
            </div>
          </div>

          <!-- Tabs -->
          <notebook>
            <page string="Overview" name="overview">
              <!-- Placeholder for custom layout inside Overview -->
              <div class="row gx-5 mt-3">
                <div class="col-md-6">
                  <h4 class="o_horizontal_separator">Latest Active Alerts</h4>
                  <field name="alert_ids" readonly="1">
                    <tree decoration-danger="severity=='critical'" decoration-warning="severity=='high'">
                      <field name="severity"/>
                      <field name="message"/>
                      <field name="create_date"/>
                      <field name="state"/>
                    </tree>
                  </field>
                </div>
                <div class="col-md-6 border-start ps-4">
                  <h4 class="o_horizontal_separator">Recent Vitals</h4>
                  <field name="vital_record_ids" readonly="1">
                    <tree>
                      <field name="recorded_at"/>
                      <field name="bp_systolic" string="SYS" class="sl-numeric"/>
                      <field name="heart_rate" string="HR" class="sl-numeric"/>
                      <field name="ai_score" string="Score" widget="progressbar"/>
                    </tree>
                  </field>
                </div>
              </div>
            </page>
            <page string="Vitals" name="vitals">
              <field name="vital_record_ids"/>
            </page>
            <page string="Alerts" name="alerts">
              <field name="alert_ids"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- PATIENT LIST VIEW -->
  <record id="view_patient_tree" model="ir.ui.view">
    <field name="name">health.patient.tree</field>
    <field name="model">health.patient</field>
    <field name="arch" type="xml">
      <tree decoration-danger="risk_level=='critical'" decoration-warning="risk_level=='high'" class="sl-modern-tree">
        <field name="name" string="Patient Name" decoration-bf="1"/>
        <field name="age" optional="show"/>
        <field name="category" widget="badge" optional="show"/>
        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
        <field name="doctor_id" widget="many2one_avatar_user"/>
        <field name="risk_level" widget="badge" 
               decoration-danger="risk_level=='critical'"
               decoration-warning="risk_level=='high'"
               decoration-info="risk_level=='medium'"
               decoration-success="risk_level=='low'"/>
        <field name="last_score" widget="progressbar" string="AI Risk Score"/>
      </tree>
    </field>
  </record>
  
  <!-- PATIENT KANBAN VIEW -->
  <record id="view_patient_kanban" model="ir.ui.view">
    <field name="name">health.patient.kanban</field>
    <field name="model">health.patient</field>
    <field name="arch" type="xml">
      <kanban>
        <field name="id"/>
        <field name="name"/>
        <field name="risk_level"/>
        <field name="last_score"/>
        <field name="doctor_id"/>
        <templates>
          <t t-name="kanban-box">
             <div class="oe_kanban_card oe_kanban_global_click"
                 t-attf-style="border-top: 4px solid #{record.risk_level.raw_value == 'critical' ? '#EF4444' : record.risk_level.raw_value == 'high' ? '#F59E0B' : record.risk_level.raw_value == 'medium' ? '#3A86FF' : '#22C55E'};">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center">
                  <!-- Simulated Avatar circle -->
                  <div class="me-3 d-flex justify-content-center align-items-center" style="width: 40px; height: 40px; border-radius: 50%; background-color: #E8F0FF; color: #3A86FF; font-weight: 600; font-size: 16px;">
                    <t t-esc="record.name.value ? record.name.value.substring(0, 2).toUpperCase() : ''"/>
                  </div>
                  <div>
                    <strong class="o_kanban_record_title" style="font-size: 16px; color: #1E293B;"><field name="name"/></strong>
                    <div style="font-size: 12px; color: #64748B;"><field name="doctor_id"/></div>
                  </div>
                </div>
                <span t-attf-class="badge #{record.risk_level.raw_value == 'critical' ? 'text-bg-danger' : record.risk_level.raw_value == 'high' ? 'text-bg-warning' : record.risk_level.raw_value == 'medium' ? 'text-bg-info' : 'text-bg-success'}">
                  <field name="risk_level"/>
                </span>
              </div>
              
              <div class="mt-3 bg-light p-2 rounded">
                <div class="d-flex justify-content-between mb-1" style="font-size: 12px;">
                  <span class="text-muted fw-bold">AI Risk Prediction</span>
                  <span class="sl-numeric"><t t-esc="Math.round((record.last_score.raw_value || 0) * 100)"/>%</span>
                </div>
                <div class="progress" style="height: 6px; border-radius: 3px;">
                  <div class="progress-bar" role="progressbar" 
                       t-attf-style="width: #{(record.last_score.raw_value || 0) * 100}%; background-color: #{record.risk_level.raw_value == 'critical' ? '#EF4444' : record.risk_level.raw_value == 'high' ? '#F59E0B' : record.risk_level.raw_value == 'medium' ? '#3A86FF' : '#22C55E'};" 
                       t-att-aria-valuenow="(record.last_score.raw_value || 0) * 100" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
              </div>
            </div>
          </t>
        </templates>
      </kanban>
    </field>
  </record>

  <!-- PATIENT SEARCH VIEW -->
  <record id="view_patient_search" model="ir.ui.view">
    <field name="name">health.patient.search</field>
    <field name="model">health.patient</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="doctor_id"/>
        <filter string="Critical Risk Patients" name="critical" domain="[('risk_level', '=', 'critical')]"/>
        <filter string="High &amp; Critical Risk" name="high_critical" domain="[('risk_level', 'in', ['high', 'critical'])]"/>
        <separator/>
        <filter string="My Patients" name="my_patients" domain="[('doctor_id', '=', uid)]"/>
        <group expand="0" string="Group By">
          <filter string="Risk Level" name="group_by_risk" context="{'group_by':'risk_level'}"/>
          <filter string="Assigned Doctor" name="group_by_doctor" context="{'group_by':'doctor_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_patients" model="ir.actions.act_window">
    <field name="name">Patients Registry</field>
    <field name="res_model">health.patient</field>
    <field name="view_mode">kanban,tree,form</field>
    <field name="search_view_id" ref="view_patient_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Register the first patient!
      </p>
      <p>
        Add a patient to start monitoring their vitals and AI risk trends.
      </p>
    </field>
  </record>

</odoo>
