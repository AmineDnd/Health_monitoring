<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Smart Router Action -->
  <record id="action_smartlab_dashboard" model="ir.actions.client">
      <field name="name">My Dashboard</field>
      <field name="tag">smartlab_dashboard_router</field>
  </record>

  <!-- Root Menu -->
  <menuitem id="menu_health_root"  name="Health SaaS" sequence="10"/>

  <!-- Smart Dashboard Menu -->
  <menuitem id="menu_smart_dashboard" name="My Dashboard" parent="menu_health_root" action="action_smartlab_dashboard" sequence="5"/>
  
  <!-- General Entities -->
  <menuitem id="menu_wards"        name="Wards"           parent="menu_health_root" action="action_health_ward" sequence="8" groups="health_monitoring.group_health_admin"/>
  <menuitem id="menu_patients"     name="All Patients"    parent="menu_health_root" action="action_patients" sequence="10"/>
  
  <menuitem id="menu_alerts"       name="Alert History"   parent="menu_health_root" action="action_all_alerts" sequence="15" groups="health_monitoring.group_health_admin"/>
  <menuitem id="menu_vitals"       name="All Vitals"      parent="menu_health_root" action="action_vitals_all" sequence="20"/>

  <!-- Analytics -->
  <menuitem id="menu_analytics_root" name="Analytics" parent="menu_health_root" sequence="30" groups="health_monitoring.group_health_admin"/>
  <menuitem id="menu_analytics_vitals" name="Vital Trends" parent="menu_analytics_root" action="action_analytics_vitals_graph" sequence="1" groups="health_monitoring.group_health_admin"/>
  <menuitem id="menu_analytics_alerts" name="Alert Severity" parent="menu_analytics_root" action="action_analytics_alerts_graph" sequence="2"  groups="health_monitoring.group_health_admin"/>
</odoo>