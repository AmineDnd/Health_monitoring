<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- VITALS FORM VIEW -->
  <record id="view_vitals_form" model="ir.ui.view">
    <field name="name">health.vital.record.form</field>
    <field name="model">health.vital.record</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button string="Analyze &amp; Save" type="object" name="action_manual_save_close" class="btn-primary ms-2" invisible="id"/>
          <field name="status" widget="statusbar" statusbar_visible="normal,warning,critical"/>
        </header>
        <sheet>
          <field name="anomaly_detected" invisible="1"/>
          
          <div class="oe_title mb-4">
            <h1 class="d-flex align-items-center text-primary">
              <i class="fa fa-heartbeat me-3"></i>Clinical Checkup
            </h1>
          </div>

          <!-- MODERN SIDEBAR LAYOUT -->
          <div class="row">
            <!-- Left Main Content: Clinical Data -->
            <div class="col-md-8">
              <div class="row sl-card-container mb-4">
                  <div class="col-md-6 mb-3">
                    <div class="sl-card shadow-sm p-4 bg-white rounded border-0 h-100">
                      <h3 class="o_horizontal_separator text-primary mb-3"><i class="fa fa-heartbeat me-2"></i>Cardiovascular</h3>
                      <group>
                        <field name="patient_id" widget="many2one_avatar" options="{'no_create': True}"/>
                        <label for="bp_systolic" string="Blood Pressure"/>
                        <div class="o_row">
                          <field name="bp_systolic" class="sl-numeric" placeholder="SYS"/>
                          <span class="mx-1">/</span>
                          <field name="bp_diastolic" class="sl-numeric" placeholder="DIA"/>
                        </div>
                        <field name="heart_rate" class="sl-numeric" string="Heart Rate (bpm)"/>
                      </group>
                    </div>
                  </div>
                  <div class="col-md-6 mb-3">
                    <div class="sl-card shadow-sm p-4 bg-white rounded border-0 h-100">
                      <h3 class="o_horizontal_separator text-info mb-3"><i class="fa fa-lungs me-2"></i>Respiratory</h3>
                      <group>
                        <field name="recorded_at"/>
                        <field name="spo2" class="sl-numeric" string="SpO2 (%)"/>
                        <field name="respiratory_rate" class="sl-numeric" string="Respiration (/min)"/>
                      </group>
                    </div>
                  </div>
              </div>
              
              <div class="row sl-card-container">
                  <div class="col-md-12">
                    <div class="sl-card shadow-sm p-4 bg-white rounded border-0">
                      <h3 class="o_horizontal_separator text-warning mb-3"><i class="fa fa-thermometer-half me-2"></i>Metabolic &amp; Temp</h3>
                      <div class="row">
                        <div class="col-md-6">
                          <group>
                            <field name="temperature" class="sl-numeric" string="Body Temp (°C)"/>
                          </group>
                        </div>
                        <div class="col-md-6">
                            <group>
                              <field name="glucose" class="sl-numeric" string="Glucose (mg/dL)"/>
                            </group>
                        </div>
                      </div>
                    </div>
                  </div>
              </div>
            </div>

            <!-- Right Sidebar: Vertical AI Assessment -->
            <div class="col-md-4">
              <div t-attf-class="sl-card shadow-lg p-4 rounded border-0 h-100 d-flex flex-column align-items-center justify-content-center text-center #{anomaly_detected and 'bg-danger-subtle border-start border-danger border-4' or 'bg-success-subtle border-start border-success border-4'}" style="min-height: 400px;">
                  <div t-attf-class="rounded-circle d-flex align-items-center justify-content-center mb-4 #{anomaly_detected and 'bg-danger text-white' or 'bg-success text-white'}" style="width: 80px; height: 80px;">
                    <i t-attf-class="fa #{anomaly_detected and 'fa-warning' or 'fa-check-circle'} fa-3x"></i>
                  </div>
                  
                  <h2 class="fw-bold mb-2 text-danger" invisible="not anomaly_detected">
                    Anomaly Detected
                  </h2>
                  <h2 class="fw-bold mb-2 text-success" invisible="anomaly_detected">
                    Normal Status
                  </h2>
                  
                  <div class="w-100 mt-4 mb-4 p-3 bg-white rounded shadow-sm border">
                    <div class="text-muted small text-uppercase fw-bold mb-2">AI Health Score</div>
                    <field name="ai_score" widget="gauge" options="{'max_field': 100, 'style': 'width:160px; height: 120px;'}"/>
                    <div class="mt-2 h4 font-monospace fw-bold" t-att-class="anomaly_detected and 'text-danger' or 'text-success'">
                      <field name="ai_score" nolabel="1"/>%
                    </div>
                  </div>

                  <div class="text-start w-100 p-3 bg-white rounded shadow-sm border flex-grow-1" style="overflow-y: auto;">
                    <div class="text-muted small text-uppercase fw-bold mb-2">Clinical Analysis</div>
                    <field name="parsed_clinical_hints" nolabel="1"/>
                  </div>
              </div>
            </div>
          </div>
        </sheet>
      </form>
    </field>
  </record>

  <!-- VITALS TREE VIEW -->
  <record id="view_vitals_tree" model="ir.ui.view">
    <field name="name">health.vital.record.tree</field>
    <field name="model">health.vital.record</field>
    <field name="arch" type="xml">
      <tree decoration-danger="status=='critical'" decoration-warning="status=='warning'" decoration-success="status=='normal'" class="sl-modern-tree">
        <field name="recorded_at" string="Timestamp"/>
        <field name="patient_id" widget="many2one_avatar"/>
        <field name="bp_systolic" string="SYS" class="sl-numeric"/>
        <field name="bp_diastolic" string="DIA" class="sl-numeric"/>
        <field name="heart_rate" string="HR" class="sl-numeric"/>
        <field name="spo2" string="SpO2" class="sl-numeric"/>
        <field name="temperature" string="Temp" class="sl-numeric"/>
        <field name="glucose" string="Glu" class="sl-numeric"/>
        <field name="ai_score" widget="progressbar" string="AI Score"/>
        <field name="status" string="Status" widget="badge" 
               decoration-danger="status=='critical'"
               decoration-warning="status=='warning'"
               decoration-success="status=='normal'"/>
      </tree>
    </field>
  </record>

  <!-- VITALS GRAPH VIEW -->
  <record id="view_vitals_graph" model="ir.ui.view">
    <field name="name">health.vital.record.graph</field>
    <field name="model">health.vital.record</field>
    <field name="arch" type="xml">
      <graph string="Vitals Analysis" type="line">
        <field name="recorded_at" interval="day"/>
        <field name="heart_rate" type="measure"/>
        <field name="bp_systolic" type="measure"/>
      </graph>
    </field>
  </record>

  <!-- VITALS PIVOT VIEW -->
  <record id="view_vitals_pivot" model="ir.ui.view">
    <field name="name">health.vital.record.pivot</field>
    <field name="model">health.vital.record</field>
    <field name="arch" type="xml">
      <pivot string="Vitals Pivot">
        <field name="recorded_at" interval="month" type="row"/>
        <field name="patient_id" type="row"/>
        <field name="heart_rate" type="measure"/>
        <field name="bp_systolic" type="measure"/>
        <field name="ai_score" type="measure"/>
      </pivot>
    </field>
  </record>

  <!-- VITALS SEARCH VIEW -->
  <record id="view_vitals_search" model="ir.ui.view">
    <field name="name">health.vital.record.search</field>
    <field name="model">health.vital.record</field>
    <field name="arch" type="xml">
      <search>
        <field name="patient_id"/>
        <filter string="Anomalies Detected" name="anomalies" domain="[('anomaly_detected', '=', True)]"/>
        <filter string="Normal Records" name="normal" domain="[('anomaly_detected', '=', False)]"/>
        <separator/>
        <filter string="Today's Vitals" name="today" domain="[('recorded_at', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('recorded_at', '&lt;=', context_today().strftime('%Y-%m-%d 23:59:59'))]"/>
        <group expand="0" string="Group By">
          <filter string="Patient" name="group_by_patient" context="{'group_by':'patient_id'}"/>
          <filter string="Date" name="group_by_date" context="{'group_by':'recorded_at:day'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ACTIONS -->
  <record id="action_vitals_all" model="ir.actions.act_window">
    <field name="name">All Vital Records</field>
    <field name="res_model">health.vital.record</field>
    <field name="view_mode">tree,form,graph</field>
    <field name="search_view_id" ref="view_vitals_search"/>
    <field name="context">{'search_default_today': 1}</field>
  </record>

  <record id="action_patient_vitals" model="ir.actions.act_window">
    <field name="name">Patient Vitals</field>
    <field name="res_model">health.vital.record</field>
    <field name="view_mode">tree,form,graph</field>
    <field name="domain">[('patient_id', '=', active_id)]</field>
    <field name="context">{'default_patient_id': active_id}</field>
  </record>

</odoo>
