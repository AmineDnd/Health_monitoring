<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="health_monitoring.NurseDashboardTemplate" owl="1">
    <div class="sl-dashboard-container sl-nurse-dashboard">

      <!-- White header -->
      <div class="sl-nurse-header">
        <div>
          <h1 style="font-size:17px;font-weight:600;color:#0F172A;margin:0;letter-spacing:-0.2px;">Central Monitor</h1>
          <p style="font-size:12px;color:#64748B;margin:3px 0 0;">
            <t t-esc="state.wardName"/> · Nurse <t t-esc="state.nurseName"/> · <t t-esc="state.patients.length"/> patients assigned
          </p>
        </div>
        <div style="display:flex;gap:8px;">
          <button class="sl-btn-ghost" t-on-click="onOpenHandoffModal">Handoff</button>
          <button class="sl-btn-primary" t-on-click="onRefresh">Refresh</button>
        </div>
      </div>

      <!-- Body -->
      <div class="sl-nurse-body">

        <!-- Stats bar -->
        <div class="sl-stats-bar">
          <div class="sl-stat-pill" style="cursor:pointer;"
               t-on-click="() => this.action.doAction('health_monitoring.action_patients')">
            <div class="sl-stat-num"><t t-esc="state.patients.length"/></div>
            <div class="sl-stat-label">Total</div>
          </div>
          <div class="sl-stat-pill stat-critical">
            <div class="sl-stat-num"><t t-esc="state.stats.critical"/></div>
            <div class="sl-stat-label">Critical</div>
          </div>
          <div class="sl-stat-pill stat-overdue">
            <div class="sl-stat-num"><t t-esc="state.stats.overdue"/></div>
            <div class="sl-stat-label">Overdue</div>
          </div>
          <div class="sl-stat-pill stat-due-soon">
            <div class="sl-stat-num"><t t-esc="state.stats.dueSoon"/></div>
            <div class="sl-stat-label">Due Soon</div>
          </div>
          <div class="sl-stat-pill stat-ok">
            <div class="sl-stat-num"><t t-esc="state.stats.ok"/></div>
            <div class="sl-stat-label">Up to Date</div>
          </div>
        </div>

        <!-- Patient card grid -->
        <div class="sl-bed-grid">
          <t t-foreach="state.patients" t-as="patient" t-key="patient.id">
            <div t-attf-class="sl-patient-card sl-status-#{patient.vitalsStatus} #{patient.risk_level === 'critical' ? 'sl-critical-pulse' : ''}">

              <!-- Card header -->
              <div class="sl-pc-inner">
                <div class="sl-pc-header">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div class="sl-avatar">
                      <t t-esc="patient.name.substring(0,1).toUpperCase()"/>
                    </div>
                    <div>
                      <div class="sl-pc-name"
                           t-on-click.stop="() => this.action.doAction({
                             type: 'ir.actions.act_window',
                             res_model: 'health.patient',
                             res_id: patient.id,
                             views: [[false,'form']],
                             target: 'current'
                           })">
                        <t t-esc="patient.name"/>
                      </div>
                      <div class="sl-pc-meta"><t t-esc="patient.timeSinceVitals"/></div>
                    </div>
                  </div>
                  <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;">
                    <span t-attf-class="sl-badge-#{patient.risk_level === 'high' ? 'warning' : (patient.risk_level || 'stable')}">
                      <t t-esc="(patient.risk_level || 'LOW').toUpperCase()"/>
                    </span>
                    <t t-if="patient.admission_status === 'admission_recommended'">
                      <span class="sl-badge-warning" style="font-size:9px;">Admit</span>
                    </t>
                  </div>
                </div>
              </div><!-- end pc-inner -->

              <!-- Vitals status banner (full-width) -->
              <div t-attf-class="sl-vitals-banner sl-banner-#{patient.vitalsStatus}">
                <span>
                  <t t-if="patient.vitalsStatus === 'overdue'">OVERDUE</t>
                  <t t-elif="patient.vitalsStatus === 'due_soon'">DUE SOON</t>
                  <t t-else="">UP TO DATE</t>
                </span>
                <span style="font-weight:400;opacity:0.85;">
                  <t t-if="patient.hoursSort != 999"><t t-esc="Math.round(patient.hoursSort * 10) / 10"/>h ago</t>
                  <t t-else="">No Vitals Yet</t>
                </span>
              </div>

              <!-- Sparkline -->
              <div class="sl-sparkline-wrap">
                <canvas t-att-id="'sparkline_' + patient.id"/>
              </div>

              <!-- Vital chips -->
              <div class="sl-vitals-chips" t-if="patient.latestHR">
                <span t-attf-class="sl-chip #{patient.hrAbnormal ? 'chip-danger' : patient.hrWarn ? 'chip-warn' : 'chip-ok'}">
                  HR <t t-esc="patient.latestHR"/>
                </span>
                <span t-attf-class="sl-chip #{patient.spo2Abnormal ? 'chip-danger' : patient.spo2Warn ? 'chip-warn' : 'chip-ok'}">
                  SpO&#8322; <t t-esc="patient.latestSpO2"/>%
                </span>
                <span t-attf-class="sl-chip #{patient.bpAbnormal ? 'chip-danger' : patient.bpWarn ? 'chip-warn' : 'chip-ok'}">
                  BP <t t-esc="patient.latestBP"/>
                </span>
              </div>
              <div class="sl-vitals-chips" t-if="!patient.latestHR">
                <span class="sl-chip chip-warn">No vitals recorded</span>
              </div>

              <!-- Log Vitals button -->
              <button class="sl-log-btn" t-on-click.stop="() => this.onLogVitals(patient.id)">
                + Log Vitals
              </button>

            </div><!-- end patient card -->
          </t>

          <t t-if="state.patients.length === 0">
            <div style="grid-column:1/-1;text-align:center;color:#94A3B8;padding:48px;font-size:14px;">
              No patients assigned to your ward.
            </div>
          </t>
        </div><!-- end bed grid -->

        <!-- Bottom row -->
        <div class="sl-bottom-row">

          <!-- Vitals schedule -->
          <div class="sl-glass-card">
            <div class="sl-card-title">Vitals Schedule</div>
            <div class="sl-scrollable-list" style="max-height:200px;">
              <t t-foreach="state.schedule" t-as="patient" t-key="patient.id">
                <div class="sl-schedule-item">
                  <span style="font-size:13px;font-weight:500;color:#0F172A;"><t t-esc="patient.name"/></span>
                  <div style="display:flex;align-items:center;gap:6px;">
                    <span t-if="patient.vitalsStatus === 'overdue'" class="sl-badge-critical"><t t-esc="patient.dueLabel"/></span>
                    <span t-elif="patient.vitalsStatus === 'due_soon'" class="sl-badge-warning">Due soon</span>
                    <span t-else="" class="sl-badge-stable">OK</span>
                    <button class="sl-btn-ghost" style="padding:3px 10px;font-size:10px;"
                            t-on-click="() => this.onLogVitals(patient.id)">Log</button>
                  </div>
                </div>
              </t>
              <t t-if="!state.schedule or state.schedule.length === 0">
                <div style="text-align:center;color:#94A3B8;padding:20px;font-size:12px;">All vitals up to date!</div>
              </t>
            </div>
          </div>

          <!-- Ward activity -->
          <div class="sl-glass-card">
            <div class="sl-card-title">Ward Activity</div>
            <div class="sl-scrollable-list" style="max-height:200px;">
              <t t-foreach="state.activityFeed" t-as="item" t-key="item.id">
                <div class="sl-activity-item">
                  <span class="sl-act-dot"
                        t-attf-style="background: #{item.type === 'alert' ? '#E24B4A' : item.type === 'vitals' ? '#16A34A' : '#185FA5'};"/>
                  <div>
                    <div class="sl-act-text"><t t-esc="item.text"/></div>
                    <div class="sl-act-time"><t t-esc="item.timeAgo"/></div>
                  </div>
                </div>
              </t>
              <t t-if="!state.activityFeed or state.activityFeed.length === 0">
                <div style="text-align:center;color:#94A3B8;padding:20px;font-size:12px;">No recent activity.</div>
              </t>
            </div>
          </div>

        </div><!-- end bottom row -->
      </div><!-- end nurse body -->

      <!-- Handoff Modal -->
      <div t-if="state.showHandoff" class="sl-modal-overlay" t-on-click="onCloseHandoffModal">
        <div class="sl-modal" t-on-click.stop="">
          <div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #EEF2F7;padding-bottom:16px;margin-bottom:20px;">
            <h3 style="margin:0;font-size:16px;font-weight:600;color:#0F172A;">Shift Handoff Report</h3>
            <button t-on-click="onCloseHandoffModal"
                    style="background:transparent;border:none;color:#94A3B8;font-size:22px;cursor:pointer;line-height:1;padding:0;">&#215;</button>
          </div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;text-align:center;">
            <div style="background:#F8FAFC;border:1px solid #EEF2F7;border-radius:10px;padding:14px;">
              <div style="font-size:28px;font-weight:700;color:#185FA5;"><t t-esc="state.patients.length"/></div>
              <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-top:4px;">Total</div>
            </div>
            <div style="background:#F8FAFC;border:1px solid #EEF2F7;border-radius:10px;padding:14px;">
              <div style="font-size:28px;font-weight:700;color:#E24B4A;"><t t-esc="state.stats.critical"/></div>
              <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-top:4px;">Critical</div>
            </div>
            <div style="background:#F8FAFC;border:1px solid #EEF2F7;border-radius:10px;padding:14px;">
              <div style="font-size:28px;font-weight:700;color:#F59E0B;"><t t-esc="state.stats.overdue"/></div>
              <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;margin-top:4px;">Overdue</div>
            </div>
          </div>
          <h5 style="font-size:11px;font-weight:600;color:#94A3B8;text-transform:uppercase;letter-spacing:0.07em;margin:0 0 12px;">High Risk Patients</h5>
          <div style="max-height:220px;overflow-y:auto;padding-right:6px;">
            <t t-foreach="state.handoffList" t-as="p" t-key="p.id">
              <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #F1F5F9;">
                <strong style="font-size:13px;color:#0F172A;"><t t-esc="p.name"/></strong>
                <div style="display:flex;gap:6px;align-items:center;">
                  <t t-if="p.latestHR">
                    <span class="sl-badge-info">HR <t t-esc="p.latestHR"/></span>
                    <span class="sl-badge-info">SpO&#8322; <t t-esc="p.latestSpO2"/>%</span>
                  </t>
                  <span t-attf-class="sl-badge-#{p.risk_level === 'high' ? 'warning' : (p.risk_level || 'stable')}">
                    <t t-esc="(p.risk_level || 'LOW').toUpperCase()"/>
                  </span>
                </div>
              </div>
            </t>
            <t t-if="!state.handoffList or state.handoffList.length === 0">
              <div style="text-align:center;color:#94A3B8;padding:20px;font-size:12px;">No high-risk patients.</div>
            </t>
          </div>
          <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid #EEF2F7;">
            <button class="sl-btn-ghost" t-on-click="onCloseHandoffModal">Close</button>
            <button class="sl-btn-ghost" t-on-click="onExportCSV">Export CSV</button>
            <button class="sl-btn-primary" t-on-click="onPrintHandoff">Print</button>
          </div>
        </div>
      </div>

    </div>
  </t>
</templates>
