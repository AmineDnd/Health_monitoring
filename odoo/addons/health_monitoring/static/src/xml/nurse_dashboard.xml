<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="health_monitoring.NurseDashboardTemplate" owl="1">
    <div class="sl-dashboard-container sl-nurse-dashboard">

      <!-- Header -->
      <div class="sl-nurse-header">
        <div>
          <h1 class="sl-title">Central Monitor</h1>
          <p class="sl-subtitle">
            <t t-esc="state.wardName"/> · Nurse <t t-esc="state.nurseName"/> · <t t-esc="state.patients.length"/> patients assigned
          </p>
        </div>
        <div class="d-flex gap-2">
          <button class="sl-btn-ghost" t-on-click="onOpenHandoffModal">
            <i class="fa fa-file-text-o me-1"/>Handoff
          </button>
          <button class="sl-btn-primary" t-on-click="onRefresh">
            <i class="fa fa-refresh me-1"/>Refresh
          </button>
        </div>
      </div>

      <!-- Scrollable body -->
      <div class="sl-nurse-body">

        <!-- Stats bar -->
        <div class="sl-stats-bar">
          <div class="sl-stat-pill">
            <div class="sl-stat-num"><t t-esc="state.patients.length"/></div>
            <div class="sl-stat-label">Total Patients</div>
          </div>
          <div class="sl-stat-pill stat-critical">
            <div class="sl-stat-num"><t t-esc="state.stats.critical"/></div>
            <div class="sl-stat-label">Critical</div>
          </div>
          <div class="sl-stat-pill stat-overdue">
            <div class="sl-stat-num"><t t-esc="state.stats.overdue"/></div>
            <div class="sl-stat-label">Overdue Vitals</div>
          </div>
          <div class="sl-stat-pill stat-due-soon">
            <div class="sl-stat-num"><t t-esc="state.stats.dueSoon"/></div>
            <div class="sl-stat-label">Due Soon</div>
          </div>
          <div class="sl-stat-pill stat-ok">
            <div class="sl-stat-num"><t t-esc="state.stats.ok"/></div>
            <div class="sl-stat-label">Up to Date</div>
          </div>
        </div>

        <!-- Bed grid -->
        <div class="sl-bed-grid">
          <t t-foreach="state.patients" t-as="patient" t-key="patient.id">
            <div t-attf-class="sl-patient-card sl-status-#{patient.vitalsStatus} #{patient.risk_level === 'critical' ? 'sl-critical-pulse' : ''}">

              <!-- Card top row -->
              <div class="sl-pc-header">
                <div class="d-flex align-items-center gap-2">
                  <div t-attf-class="sl-avatar sl-avatar-#{patient.risk_level}">
                    <t t-esc="patient.name.substring(0,1).toUpperCase()"/>
                  </div>
                  <div>
                    <div class="sl-pc-name"><t t-esc="patient.name"/></div>
                    <div class="sl-pc-meta"><t t-esc="patient.timeSinceVitals"/></div>
                  </div>
                </div>
                <span t-attf-class="sl-badge sl-badge-#{patient.risk_level}">
                  <t t-esc="(patient.risk_level || 'low').toUpperCase()"/>
                </span>
              </div>

              <!-- Vitals status banner -->
              <div t-attf-class="sl-vitals-banner sl-banner-#{patient.vitalsStatus}">
                <span>
                  <i class="fa fa-clock-o me-1"/>
                  <t t-if="patient.vitalsStatus === 'overdue'">OVERDUE</t>
                  <t t-elif="patient.vitalsStatus === 'due_soon'">Due Soon</t>
                  <t t-else="">Up to Date</t>
                </span>
                <span>
                  <t t-if="patient.hoursSort != 999"><t t-esc="Math.round(patient.hoursSort * 10) / 10"/>h ago</t>
                  <t t-else="">No Vitals Yet</t>
                </span>
              </div>

              <!-- Sparkline canvas — fixed height -->
              <div class="sl-sparkline-wrap">
                <canvas t-att-id="'sparkline_' + patient.id"/>
              </div>

              <!-- Vital chips with color coding -->
              <div class="sl-vitals-chips" t-if="patient.latestHR">
                <span t-attf-class="sl-chip #{patient.hrAbnormal ? 'chip-danger' : patient.hrWarn ? 'chip-warn' : 'chip-ok'}">
                  HR <t t-esc="patient.latestHR"/>
                </span>
                <span t-attf-class="sl-chip #{patient.spo2Abnormal ? 'chip-danger' : patient.spo2Warn ? 'chip-warn' : 'chip-ok'}">
                  SpO&#8322; <t t-esc="patient.latestSpO2"/>%
                </span>
                <span t-attf-class="sl-chip #{patient.bpAbnormal ? 'chip-danger' : patient.bpWarn ? 'chip-warn' : 'chip-ok'}">
                  BP <t t-esc="patient.latestBP"/>
                </span>
              </div>
              <div class="sl-vitals-chips" t-if="!patient.latestHR">
                <span class="sl-chip chip-warn">No vitals recorded</span>
              </div>

              <!-- Log vitals button -->
              <button class="sl-log-btn" t-on-click.stop="() => this.onLogVitals(patient.id)">
                <i class="fa fa-plus me-1"/>Log Vitals
              </button>

            </div>
          </t>
          <t t-if="state.patients.length === 0">
            <div class="text-center py-5 text-muted" style="grid-column:1/-1">
              <i class="fa fa-bed fa-2x d-block mb-2"/>
              <p>No admitted patients found in this ward.</p>
            </div>
          </t>
        </div>

        <!-- Bottom row: Schedule + Activity -->
        <div class="sl-bottom-row">

          <!-- Vitals schedule -->
          <div class="sl-glass-card">
            <div class="sl-card-title"><i class="fa fa-calendar-check-o text-primary me-1"/>Vitals Schedule</div>
            <div class="sl-scrollable-list" style="max-height:200px">
              <t t-foreach="state.schedule" t-as="patient" t-key="patient.id">
                <div class="sl-schedule-item">
                  <span style="font-size:13px;font-weight:500"><t t-esc="patient.name"/></span>
                  <div class="d-flex align-items-center gap-2">
                    <t t-if="patient.vitalsStatus === 'overdue'">
                      <span class="sl-badge sl-badge-critical"><t t-esc="patient.dueLabel"/></span>
                    </t>
                    <t t-elif="patient.vitalsStatus === 'due_soon'">
                      <span class="sl-badge sl-badge-warning">Due soon</span>
                    </t>
                    <t t-else="">
                      <span class="sl-badge sl-badge-stable">OK</span>
                    </t>
                    <button class="sl-log-btn" style="width:auto;padding:3px 8px;margin:0" t-on-click="() => this.onLogVitals(patient.id)">Log</button>
                  </div>
                </div>
              </t>
              <t t-if="!state.schedule or state.schedule.length === 0">
                <div class="text-muted small text-center py-3">All vitals up to date!</div>
              </t>
            </div>
          </div>

          <!-- Ward activity feed -->
          <div class="sl-glass-card">
            <div class="sl-card-title"><i class="fa fa-feed text-primary me-1"/>Ward Activity</div>
            <div class="sl-scrollable-list" style="max-height:200px">
              <t t-foreach="state.activityFeed" t-as="item" t-key="item.id">
                <div class="sl-activity-item">
                  <span class="sl-act-dot" t-attf-style="background:#{item.type === 'alert' ? '#EF4444' : item.type === 'vitals' ? '#10B981' : '#3B82F6'}"/>
                  <div>
                    <div class="sl-act-text"><t t-esc="item.text"/></div>
                    <div class="sl-act-time"><t t-esc="item.timeAgo"/></div>
                  </div>
                </div>
              </t>
              <t t-if="!state.activityFeed or state.activityFeed.length === 0">
                <div class="text-muted small text-center py-3">No recent activity.</div>
              </t>
            </div>
          </div>

        </div><!-- end bottom row -->
      </div><!-- end nurse body -->

      <!-- Handoff Modal -->
      <div t-if="state.showHandoff" class="sl-modal-overlay" t-on-click="onCloseHandoffModal">
        <div class="sl-modal" t-on-click.stop="">
          <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
            <h3 class="m-0 fw-bold" style="font-size:16px">
              <i class="fa fa-file-text-o text-primary me-2"/>Shift Handoff Report
            </h3>
            <button class="btn-close" t-on-click="onCloseHandoffModal"/>
          </div>
          <div class="row text-center mb-4">
            <div class="col-4">
              <div style="font-size:28px;font-weight:700;color:#3B82F6"><t t-esc="state.patients.length"/></div>
              <div class="small text-muted">Total</div>
            </div>
            <div class="col-4">
              <div style="font-size:28px;font-weight:700;color:#EF4444"><t t-esc="state.stats.critical"/></div>
              <div class="small text-muted">Critical</div>
            </div>
            <div class="col-4">
              <div style="font-size:28px;font-weight:700;color:#F59E0B"><t t-esc="state.stats.overdue"/></div>
              <div class="small text-muted">Overdue</div>
            </div>
          </div>
          <h5 class="fw-bold mb-3" style="font-size:13px">High Risk Patients</h5>
          <div style="max-height:220px;overflow-y:auto">
            <t t-foreach="state.handoffList" t-as="p" t-key="p.id">
              <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                <strong style="font-size:13px"><t t-esc="p.name"/></strong>
                <div class="d-flex align-items-center gap-2">
                  <t t-if="p.latestHR">
                    <span class="sl-badge sl-badge-info">HR <t t-esc="p.latestHR"/></span>
                    <span class="sl-badge sl-badge-info">SpO₂ <t t-esc="p.latestSpO2"/>%</span>
                  </t>
                  <span t-attf-class="sl-badge sl-badge-#{p.risk_level}">
                    <t t-esc="(p.risk_level || 'low').toUpperCase()"/>
                  </span>
                </div>
              </div>
            </t>
            <t t-if="!state.handoffList or state.handoffList.length === 0">
              <div class="text-muted text-center py-3 small">No high-risk patients.</div>
            </t>
          </div>
          <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
            <button class="sl-btn-ghost" t-on-click="onCloseHandoffModal">Close</button>
            <button class="sl-btn-ghost" t-on-click="onExportCSV"><i class="fa fa-download me-1"/>CSV</button>
            <button class="sl-btn-primary" t-on-click="onPrintHandoff"><i class="fa fa-print me-1"/>Print</button>
          </div>
        </div>
      </div>

    </div>
  </t>
</templates>
