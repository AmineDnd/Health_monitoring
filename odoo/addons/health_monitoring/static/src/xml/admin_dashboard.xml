<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
  <t t-name="health_monitoring.AdminDashboardTemplate" owl="1">
    <div class="sl-dashboard-container sl-admin-dashboard">

      <!-- Dark header bar -->
      <div class="sl-admin-header">
        <div>
          <h1 class="sl-title">Hospital Operations</h1>
          <p class="sl-subtitle">SmartLab Control Center · Real-time analytics · <t t-esc="state.currentTime"/></p>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="display:flex;gap:6px;">
            <button t-on-click="() => this.setRange('today')"
                    t-att-class="state.dateRange === 'today' ? 'sl-header-btn active' : 'sl-header-btn'">
              Today
            </button>
            <button t-on-click="() => this.setRange('week')"
                    t-att-class="state.dateRange === 'week' ? 'sl-header-btn active' : 'sl-header-btn'">
              This Week
            </button>
            <button t-on-click="() => this.setRange('month')"
                    t-att-class="state.dateRange === 'month' ? 'sl-header-btn active' : 'sl-header-btn'">
              Month
            </button>
          </div>
          <span class="sl-live-badge">
            <span class="sl-live-dot"/>
            Live
          </span>
        </div>
      </div>

      <!-- Light body -->
      <div class="sl-admin-body">

        <!-- Loading state -->
        <t t-if="state.isLoading">
          <div class="sl-kpi-row">
            <div class="sl-kpi-card sl-skeleton" style="height:100px;"><div class="sl-skeleton-shimmer"/></div>
            <div class="sl-kpi-card sl-skeleton" style="height:100px;"><div class="sl-skeleton-shimmer"/></div>
            <div class="sl-kpi-card sl-skeleton" style="height:100px;"><div class="sl-skeleton-shimmer"/></div>
            <div class="sl-kpi-card sl-skeleton" style="height:100px;"><div class="sl-skeleton-shimmer"/></div>
          </div>
        </t>

        <t t-else="">

          <!-- KPI Row -->
          <div class="sl-kpi-row sl-animate-in">
            <div class="sl-kpi-card kpi-patients" style="cursor:pointer;" t-on-click="openAllPatients">
              <div class="sl-kpi-label">Active Patients</div>
              <div class="sl-kpi-value"><t t-esc="state.kpi.activePatients"/></div>
              <div class="sl-kpi-delta up">+<t t-esc="state.kpi.activeDelta"/> since yesterday</div>
            </div>
            <div class="sl-kpi-card kpi-critical" style="cursor:pointer;" t-on-click="openAllAlerts">
              <div class="sl-kpi-label">Critical Alerts</div>
              <div class="sl-kpi-value"><t t-esc="state.kpi.criticalAlerts"/></div>
              <div class="sl-kpi-delta"><t t-esc="state.kpi.criticalDelta"/> in last hour</div>
            </div>
            <div class="sl-kpi-card kpi-response">
              <div class="sl-kpi-label">Avg Response Time</div>
              <div class="sl-kpi-value"><t t-esc="state.kpi.avgResponse"/></div>
              <div class="sl-kpi-delta">from alert to resolution</div>
            </div>
            <div class="sl-kpi-card kpi-anomalies">
              <div class="sl-kpi-label">AI Anomalies Today</div>
              <div class="sl-kpi-value"><t t-esc="state.kpi.aiAnomalies"/></div>
              <div class="sl-kpi-delta">alerts triggered today</div>
            </div>
          </div>

          <!-- Row 2: Ward Capacity + Patient Status + Doctor Performance -->
          <div style="display:grid;grid-template-columns:1.6fr 1fr 1.4fr;gap:14px;margin-bottom:16px;">

            <!-- Ward Capacity -->
            <div class="sl-glass-card">
              <div class="sl-card-title">Ward Capacity</div>
              <div class="sl-scrollable-list" style="max-height:260px;">
                <t t-foreach="state.wards" t-as="ward" t-key="ward.id">
                  <div class="sl-ward-bar-row">
                    <span class="sl-ward-label" t-att-title="ward.name"><t t-esc="ward.name"/></span>
                    <div class="sl-ward-track">
                      <div class="sl-ward-fill"
                           t-attf-style="width:#{ward.pct}%; background: #{ward.pct >= 85 ? '#E24B4A' : (ward.pct >= 65 ? '#F59E0B' : '#16A34A')};"/>
                    </div>
                    <span class="sl-ward-pct"
                          t-attf-style="color: #{ward.pct >= 85 ? '#E24B4A' : (ward.pct >= 65 ? '#F59E0B' : '#16A34A')};">
                      <t t-esc="ward.pct"/>%
                    </span>
                  </div>
                </t>
                <t t-if="!state.wards or state.wards.length === 0">
                  <div style="text-align:center;color:#94A3B8;padding:24px;font-size:13px;">No ward data available.</div>
                </t>
              </div>
            </div>

            <!-- Patient Status Donut -->
            <div class="sl-glass-card" style="display:flex;flex-direction:column;">
              <div class="sl-card-title">Patient Status</div>
              <div style="flex:1;position:relative;min-height:160px;">
                <canvas t-ref="statusChart"/>
              </div>
              <div style="display:flex;justify-content:space-around;padding-top:10px;border-top:1px solid #F1F5F9;margin-top:8px;">
                <div style="text-align:center;">
                  <div style="font-size:18px;font-weight:700;color:#16A34A;"><t t-esc="state.patientStatus.stable"/></div>
                  <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;">Stable</div>
                </div>
                <div style="text-align:center;">
                  <div style="font-size:18px;font-weight:700;color:#F59E0B;"><t t-esc="state.patientStatus.warning"/></div>
                  <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;">Warning</div>
                </div>
                <div style="text-align:center;">
                  <div style="font-size:18px;font-weight:700;color:#E24B4A;"><t t-esc="state.patientStatus.critical"/></div>
                  <div style="font-size:9px;color:#94A3B8;text-transform:uppercase;letter-spacing:0.06em;">Critical</div>
                </div>
              </div>
            </div>

            <!-- Doctor Performance -->
            <div class="sl-glass-card" style="display:flex;flex-direction:column;">
              <div class="sl-card-title">Doctor Performance</div>
              <div class="sl-scrollable-list" style="flex:1;max-height:260px;">
                <t t-foreach="state.leaderboard" t-as="doc" t-key="doc.id">
                  <div class="sl-lb-row" t-on-click="() => this.openDoctorAlerts(doc.id, doc.name)">
                    <div>
                      <div class="sl-lb-name"><t t-esc="doc.name"/></div>
                      <div style="font-size:11px;color:#64748B;margin-top:2px;"><t t-esc="doc.total"/> handled</div>
                    </div>
                    <div class="sl-lb-stats">
                      <span class="sl-badge-stable"><t t-esc="doc.resolved"/> resolved</span>
                      <span class="sl-badge-critical" t-if="doc.critical > 0"><t t-esc="doc.critical"/> critical</span>
                    </div>
                  </div>
                </t>
                <t t-if="state.leaderboard.length === 0">
                  <div style="text-align:center;color:#94A3B8;padding:24px;font-size:13px;">No data yet.</div>
                </t>
              </div>
            </div>
          </div>

          <!-- Row 3: Alert Trend + AI Insights -->
          <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:16px;">
            <div class="sl-glass-card">
              <div class="sl-card-title">Alert Trend — Last 7 Days</div>
              <div style="height:160px;position:relative;">
                <canvas t-ref="trendChart"/>
              </div>
            </div>
            <div class="sl-glass-card" style="display:flex;flex-direction:column;">
              <div class="sl-card-title">AI Insights</div>
              <div class="sl-scrollable-list" style="flex:1;max-height:160px;">
                <t t-foreach="state.insights" t-as="insight" t-key="insight">
                  <div style="border-left:3px solid #185FA5;border-radius:0 6px 6px 0;font-size:12px;color:#0F172A;background:#F0F7FF;padding:8px 10px;margin-bottom:6px;line-height:1.4;">
                    <t t-esc="insight"/>
                  </div>
                </t>
                <t t-if="!state.insights or state.insights.length === 0">
                  <div style="text-align:center;color:#94A3B8;padding:24px;font-size:12px;">Collecting data...</div>
                </t>
              </div>
            </div>
          </div>

          <!-- Row 4: Recent Escalations -->
          <div class="sl-glass-card">
            <div class="sl-card-title">Recent Critical Escalations</div>
            <div class="sl-scrollable-list" style="max-height:240px;">
              <t t-foreach="state.escalations" t-as="esc" t-key="esc.id">
                <div class="sl-escalation-item" t-on-click="() => this.openAlert(esc.id)">
                  <div class="sl-esc-dot"/>
                  <div style="flex:1;">
                    <div class="sl-esc-text"><t t-esc="esc.headline"/></div>
                    <div class="sl-esc-meta">
                      <t t-esc="esc.timeAgo"/>
                      <t t-if="esc.patient_id">
                        <span style="margin-left:6px;color:#185FA5;cursor:pointer;"
                              t-on-click.stop="() => this.openPatient(esc.patient_id[0])">
                          · <t t-esc="esc.patient_id[1]"/>
                        </span>
                      </t>
                    </div>
                  </div>
                  <span t-attf-class="sl-badge-#{esc.severity === 'high' ? 'warning' : esc.severity}">
                    <t t-esc="esc.severity"/>
                  </span>
                </div>
              </t>
              <t t-if="state.escalations.length === 0">
                <div style="text-align:center;color:#94A3B8;padding:24px;font-size:13px;">No recent escalations.</div>
              </t>
            </div>
          </div>

        </t><!-- end t-else -->
      </div><!-- end admin body -->
    </div>
  </t>
</templates>
