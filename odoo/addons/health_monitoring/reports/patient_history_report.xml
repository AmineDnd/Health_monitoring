<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_patient_history" model="ir.actions.report">
        <field name="name">Patient Vital History</field>
        <field name="model">health.patient</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">health_monitoring.report_patient_history_view</field>
        <field name="report_file">health_monitoring.report_patient_history_view</field>
        <field name="print_report_name">'Vitals_History_%s' % (object.name or 'Patient')</field>
        <field name="binding_model_id" ref="model_health_patient"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_patient_history_view">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="mb-4">Patient Vital History</h2>
                        <div class="row bg-light p-3 mb-4 rounded border">
                            <div class="col-6">
                                <strong>Name:</strong> <span t-field="doc.name"/><br/>
                                <strong>Age:</strong> <span t-field="doc.age"/><br/>
                                <strong>Gender:</strong> <span t-field="doc.gender"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Assigned Doctor:</strong> <span t-field="doc.doctor_id.name"/><br/>
                                <strong>Current Risk Level:</strong> <span t-field="doc.risk_level"/><br/>
                                <strong>Latest AI Score:</strong> <span t-field="doc.last_score"/>
                            </div>
                        </div>

                        <h4 class="mt-4 mb-3" style="color:#0D9488; border-bottom: 2px solid #0D9488;">Clinical Checkups History</h4>
                        <table class="table table-sm table-striped" style="font-size: 11px;">
                            <thead>
                                <tr class="table-primary">
                                    <th>Date</th>
                                    <th>BP (SYS/DIA)</th>
                                    <th>HR (bpm)</th>
                                    <th>SpO2 (%)</th>
                                    <th>Temp (°C)</th>
                                    <th>Glucose</th>
                                    <th>Resp</th>
                                    <th>Risk Score</th>
                                    <th>Result</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.vital_record_ids.sorted(key=lambda r: r.recorded_at, reverse=True)" t-as="vital">
                                    <tr t-att-class="'table-danger font-weight-bold' if vital.status == 'critical' else 'table-warning' if vital.status == 'warning' else ''">
                                        <td><span t-field="vital.recorded_at" t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/></td>
                                        <td><span t-field="vital.bp_systolic"/> / <span t-field="vital.bp_diastolic"/></td>
                                        <td><span t-field="vital.heart_rate"/></td>
                                        <td><span t-field="vital.spo2"/></td>
                                        <td><span t-field="vital.temperature"/></td>
                                        <td><span t-field="vital.glucose"/></td>
                                        <td><span t-field="vital.respiratory_rate"/></td>
                                        <td><span t-field="vital.ai_score" t-options='{"widget": "percentage"}'/></td>
                                        <td>
                                            <span t-if="vital.status == 'critical'" class="badge text-bg-danger">CRITICAL</span>
                                            <span t-elif="vital.status == 'warning'" class="badge text-bg-warning">WARNING</span>
                                            <span t-else="" class="text-success">Normal</span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        
                        <t t-if="doc.alert_ids">
                            <h4 class="mt-5 mb-3" style="color:#DC2626; border-bottom: 2px solid #DC2626;">Recent Alerts</h4>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Severity</th>
                                        <th>Message</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.alert_ids.sorted(key=lambda r: r.create_date, reverse=True)[:10]" t-as="alert">
                                        <tr t-att-class="'table-danger' if alert.severity == 'critical' else 'table-warning' if alert.severity == 'high' else 'table-info' if alert.severity == 'medium' else ''">
                                            <td><span t-field="alert.create_date" t-options='{"widget": "datetime"}'/></td>
                                            <td class="text-uppercase fw-bold"><span t-field="alert.severity"/></td>
                                            <td><span t-field="alert.message"/></td>
                                            <td><span t-field="alert.state"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
