<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_health_monitoring" model="ir.module.category">
            <field name="name">Health Monitoring</field>
            <field name="description">Helps you manage your healthcare system.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_health_nurse" model="res.groups">
            <field name="name">Nurse</field>
            <field name="category_id" ref="module_category_health_monitoring"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_health_doctor" model="res.groups">
            <field name="name">Doctor</field>
            <field name="category_id" ref="module_category_health_monitoring"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        </record>
        
        <record id="group_health_admin" model="res.groups">
            <field name="name">Boss (Administrator)</field>
            <field name="category_id" ref="module_category_health_monitoring"/>
            <field name="implied_ids" eval="[(4, ref('group_health_doctor')), (4, ref('base.group_system'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
