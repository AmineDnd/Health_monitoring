<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Doctors only see patients assigned to their wards OR unassigned patients -->
        <record id="rule_doctor_patient_ward" model="ir.rule">
            <field name="name">Doctor Ward Patients</field>
            <field name="model_id" ref="model_health_patient"/>
            <field name="domain_force">['|', ('ward_id', '=', False), ('ward_id.doctor_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('health_monitoring.group_health_doctor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Admins and Nurses see all patients (global rules) -->
        <record id="rule_all_patient_admin_nurse" model="ir.rule">
            <field name="name">Admin/Nurse All Patients</field>
            <field name="model_id" ref="model_health_patient"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('health_monitoring.group_health_admin')), (4, ref('health_monitoring.group_health_nurse'))]"/>
        </record>

    </data>
</odoo>
